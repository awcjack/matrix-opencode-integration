# Matrix Configuration
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=@opencode-bot:matrix.org
MATRIX_ACCESS_TOKEN=your_access_token_here
MATRIX_DEVICE_ID=

# OpenCode Configuration
OPENCODE_SERVER_URL=http://localhost:4096
OPENCODE_USERNAME=opencode
OPENCODE_PASSWORD=

# Whitelist (JSON array or comma-separated)
MATRIX_WHITELIST=["@your-user:matrix.org"]
# Or: MATRIX_WHITELIST=@user1:matrix.org,@user2:matrix.org

# Default provider and agent (optional)
OPENCODE_DEFAULT_PROVIDER=
OPENCODE_DEFAULT_AGENT=
